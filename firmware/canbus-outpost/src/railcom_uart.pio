.program railcom_uart

; Standard UART RX at 250kbps.
; Assumes 10 cycles per bit.
; Samples in the middle of each bit.

.wrap_target
    wait 0 pin 0        ; Wait for start bit (falling edge)
    set x, 7      [4]   ; Preload bit counter, wait 5 cycles to reach middle of bit 0
sample_loop:
    in pins, 1    [7]   ; Sample bit, wait 7 cycles
    jmp x-- sample_loop [1] ; Jump back, wait 1 cycle. Total loop is 10 cycles.
.wrap
